# Database Configuration
DATABASE_URL=postgresql://credpay:dev-password-change-in-prod@postgres:5432/credpay

# Redis Configuration
REDIS_URL=redis://:dev-password@redis:6379
REDIS_PASSWORD=dev-password

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# JWT Configuration (generate these securely in production)
JWT_SECRET=dev-secret-change-in-prod
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# JWT Options
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d
REFRESH_TOKEN_SECRET=dev-refresh-secret-change-in-prod

# Razorpay Integration (mock by default in development)
RAZORPAY_ENV=sandbox
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=webhook-secret-rotate-me

# Cashfree Integration (mock by default in development)
CASHFREE_ENV=sandbox
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=

# Email Configuration (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@credpay.com

# SMS Configuration (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS Configuration (optional, for S3 backups)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=credpay-backups

# Monitoring & Observability
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
ENABLE_MOCK_PAYMENTS=true
ENABLE_MOCK_PAYOUTS=true
ENABLE_PAYMENT_WEBHOOKS=true
ENABLE_PAYOUT_WEBHOOKS=true

# Security
CORS_ORIGIN=http://localhost:3001,http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Configuration
ADMIN_EMAIL=admin@credpay.com
ADMIN_PASSWORD=  # Will be set during setup
